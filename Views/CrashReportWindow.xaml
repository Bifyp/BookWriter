<Window x:Class="BookWriter.Views.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BookWriter — Критическая ошибка"
        Width="580" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#050810"
        BorderBrush="#330022" BorderThickness="1">

    <DockPanel Margin="0">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#0A0510"
                BorderBrush="#330022" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="⚠" FontSize="22" Foreground="#FF007A"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="КРИТИЧЕСКАЯ ОШИБКА"
                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                               Foreground="#FF007A" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF007A" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                <TextBlock x:Name="ErrorMessage"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#C8E6FF" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border DockPanel.Dock="Bottom" Background="#070D1B"
                BorderBrush="#091828" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="ReportPathText"
                           Foreground="#3A6080" FontFamily="Consolas" FontSize="9"
                           VerticalAlignment="Center" Margin="0,0,16,0"
                           TextTrimming="CharacterEllipsis" MaxWidth="250"/>
                <Button Content="📋 Копировать" Click="Copy_Click"
                        Background="Transparent" BorderBrush="#0D2235"
                        Foreground="#3A6080" FontFamily="Consolas" FontSize="10"
                        Padding="10,5" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="📂 Открыть папку" Click="OpenFolder_Click"
                        Background="Transparent" BorderBrush="#0D2235"
                        Foreground="#3A6080" FontFamily="Consolas" FontSize="10"
                        Padding="10,5" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="✕ Закрыть" Click="Close_Click"
                        Background="#FF007A" BorderBrush="#FF007A"
                        Foreground="#050810" FontFamily="Consolas" FontSize="10"
                        FontWeight="Bold" Padding="12,5" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Stack trace -->
        <Border Margin="0" Background="#030608">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="StackTraceBox"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#3A6080"
                         BorderThickness="0"
                         FontFamily="Consolas" FontSize="10"
                         TextWrapping="NoWrap"
                         Margin="16,12"
                         CaretBrush="#FF007A"/>
            </ScrollViewer>
        </Border>

    </DockPanel>
</Window>
