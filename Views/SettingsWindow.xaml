<Window x:Class="BookWriter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="// SETTINGS" Width="480" Height="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#050810" BorderBrush="#0D2235" BorderThickness="1">
    <Border Padding="28,24" Background="#070D1B"
            BorderBrush="#003322" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="// BOOK SETTINGS" FontFamily="Consolas" FontSize="13"
                       FontWeight="Bold" Foreground="#00FFCC" Margin="0,0,0,20">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFCC" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Font -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="FONT FAMILY" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="FontFamilyBox"/>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="FONT SIZE (pt)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="FontSizeBox"/>
            </Grid>

            <!-- Page dimensions -->
            <TextBlock Text="PAGE DIMENSIONS (mm)" FontFamily="Consolas" FontSize="10"
                       Foreground="#3A6080" Margin="0,8,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="WIDTH / HEIGHT" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="PageWidthBox"/>
                <TextBlock Grid.Column="2" Text="×" Foreground="#3A6080"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="3" x:Name="PageHeightBox"/>
            </Grid>

            <!-- Margins -->
            <TextBlock Text="MARGINS (mm)" FontFamily="Consolas" FontSize="10"
                       Foreground="#3A6080" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <Label Content="TOP"/>
                    <TextBox x:Name="MarginTopBox"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,4,0">
                    <Label Content="BOTTOM"/>
                    <TextBox x:Name="MarginBottomBox"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,4,0">
                    <Label Content="LEFT"/>
                    <TextBox x:Name="MarginLeftBox"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <Label Content="RIGHT"/>
                    <TextBox x:Name="MarginRightBox"/>
                </StackPanel>
            </Grid>

            <!-- Theme toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <CheckBox x:Name="DarkThemeCheck"
                          Content="NEON PINK VARIANT"
                          Foreground="#C8E6FF" FontFamily="Consolas" FontSize="12"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="[ CANCEL ]" Width="100" Height="32" Margin="0,0,10,0"
                        FontFamily="Consolas" FontSize="11"
                        Foreground="#3A6080" Background="Transparent"
                        BorderBrush="#0D2235" Click="Cancel_Click"/>
                <Button Content="[ APPLY ]" Width="100" Height="32"
                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                        Foreground="#050810" Background="#00FFCC"
                        BorderBrush="#00FFCC" Click="Apply_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
