<Window x:Class="BookWriter.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="INPUT" Width="400" Height="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#050810"
        BorderBrush="#0D2235" BorderThickness="1">
    <Border Padding="24,20" BorderBrush="#003322" BorderThickness="1"
            Background="#070D1B">
        <StackPanel>
            <TextBlock x:Name="LabelText" Text="Value:"
                       Foreground="#3A6080" FontFamily="Consolas" FontSize="11"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="InputBox" FontFamily="Consolas" FontSize="13"
                     Foreground="#C8E6FF" Background="#04060E"
                     BorderBrush="#003322" Padding="8,6"
                     KeyDown="InputBox_KeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="[ CANCEL ]" Width="90" Height="30"
                        FontFamily="Consolas" FontSize="11"
                        Foreground="#3A6080" Background="Transparent"
                        BorderBrush="#0D2235" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="[ OK ]" Width="90" Height="30"
                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                        Foreground="#050810" Background="#00FFCC"
                        BorderBrush="#00FFCC"
                        Click="OK_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
