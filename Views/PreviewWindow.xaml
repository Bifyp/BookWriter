<Window x:Class="BookWriter.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="// BOOK PREVIEW" Width="900" Height="820"
        WindowStartupLocation="CenterOwner"
        Background="#050810"
        BorderBrush="#003322" BorderThickness="1">

    <Window.Resources>
        <DropShadowEffect x:Key="NeonGlow" Color="#00FFCC" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#080E1C"
                BorderBrush="#091828" BorderThickness="0,0,0,1" Padding="10,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="// BOOK PREVIEW"
                           Foreground="#00FFCC" FontFamily="Consolas"
                           FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Effect="{StaticResource NeonGlow}"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="PageInfo" Text="Страница 1 из 1"
                               Foreground="#3A6080" FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <Button x:Name="PrevBtn" Content="◀ Пред"
                            Click="PrevPage_Click"
                            Background="Transparent" BorderBrush="#0D2235"
                            Foreground="#3A6080" FontFamily="Consolas" FontSize="10"
                            Padding="8,4" Cursor="Hand" Margin="0,0,4,0"/>

                    <Button x:Name="NextBtn" Content="След ▶"
                            Click="NextPage_Click"
                            Background="Transparent" BorderBrush="#0D2235"
                            Foreground="#3A6080" FontFamily="Consolas" FontSize="10"
                            Padding="8,4" Cursor="Hand" Margin="0,0,12,0"/>

                    <Button Content="✕ Закрыть"
                            Click="Close_Click"
                            Background="Transparent" BorderBrush="#330022"
                            Foreground="#FF007A" FontFamily="Consolas" FontSize="10"
                            Padding="8,4" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Page viewer -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="#04060E">
            <Grid>
                <!-- Page content -->
                <Border x:Name="PageBorder"
                        Width="595" MinHeight="842"
                        Margin="40,30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="#0B1122"
                        BorderBrush="#003322" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#00FFCC" BlurRadius="30"
                                          ShadowDepth="0" Opacity="0.05"/>
                    </Border.Effect>

                    <!-- Page corners decoration -->
                    <Grid>
                        <Canvas>
                            <!-- TL corner -->
                            <Border Canvas.Left="12" Canvas.Top="12"
                                    Width="20" Height="20"
                                    BorderBrush="#2600FFCC"
                                    BorderThickness="1,1,0,0"/>
                            <!-- TR corner -->
                            <Border Canvas.Right="12" Canvas.Top="12"
                                    Width="20" Height="20"
                                    BorderBrush="#2600FFCC"
                                    BorderThickness="0,1,1,0"/>
                        </Canvas>

                        <!-- Actual page content -->
                        <FlowDocumentScrollViewer x:Name="PageViewer"
                                                   VerticalScrollBarVisibility="Disabled"
                                                   HorizontalScrollBarVisibility="Disabled"
                                                   IsToolBarVisible="False"
                                                   Foreground="#C8E6FF"
                                                   FontFamily="Consolas"
                                                   Margin="60,50"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
