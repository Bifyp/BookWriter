<Window x:Class="BookWriter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BookWriter.ViewModels"
        Title="BOOKWRITER // CYBER-EDITION"
        Width="1380" Height="840"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <DropShadowEffect x:Key="NeonGlow"  Color="#00FFCC" BlurRadius="8"  ShadowDepth="0" Opacity="0.9"/>
        <DropShadowEffect x:Key="PinkGlow"  Color="#FF007A" BlurRadius="8"  ShadowDepth="0" Opacity="0.8"/>
        <DropShadowEffect x:Key="SubGlow"   Color="#00FFCC" BlurRadius="4"  ShadowDepth="0" Opacity="0.4"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding OpenFindCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ░░ MENU BAR ░░ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource MenuBackground}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <Menu.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </Menu.ItemsPanel>

                <MenuItem Header="[ FILE ]" Foreground="{DynamicResource NeonCyan}"
                          FontFamily="Consolas" FontSize="12" FontWeight="Bold">
                    <MenuItem Header="▸ NEW"            Command="{Binding NewCommand}"        InputGestureText="Ctrl+N"/>
                    <MenuItem Header="▸ OPEN…"          Command="{Binding OpenCommand}"       InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="▸ SAVE"           Command="{Binding SaveCommand}"       InputGestureText="Ctrl+S"/>
                    <MenuItem Header="▸ SAVE AS…"       Command="{Binding SaveAsCommand}"/>
                    <Separator/>
                    <MenuItem Header="▸ EXPORT → PDF"   Command="{Binding ExportPdfCommand}"/>
                    <MenuItem Header="▸ EXPORT → EPUB"  Command="{Binding ExportEpubCommand}"/>
                    <Separator/>
                    <MenuItem Header="▸ PRINT"          Command="{Binding PrintCommand}"      InputGestureText="Ctrl+P"/>
                </MenuItem>

                <MenuItem Header="[ VIEW ]" Foreground="{DynamicResource NeonCyan}"
                          FontFamily="Consolas" FontSize="12" FontWeight="Bold">
                    <MenuItem Header="▸ TOGGLE THEME"      Command="{Binding ToggleThemeCommand}"/>
                    <MenuItem Header="▸ COVER EDITOR…"     Command="{Binding OpenCoverEditorCommand}"/>
                    <MenuItem Header="▸ LIBRARY / DB…"     Command="{Binding OpenLibraryCommand}"/>
                    <MenuItem Header="▸ REVISION HISTORY…" Command="{Binding OpenRevisionsCommand}"/>
                    <Separator/>
                    <MenuItem Header="▸ 👁 ПРЕДПРОСМОТР КНИГИ" Command="{Binding OpenPreviewCommand}"
                              FontWeight="Bold" Foreground="{DynamicResource NeonYellow}"/>
                </MenuItem>

                <MenuItem Header="[ SETTINGS ]" Foreground="{DynamicResource NeonCyan}"
                          FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                          Command="{Binding OpenSettingsCommand}"/>


                <MenuItem Header="[ ABOUT ]" Foreground="{DynamicResource SecondaryText}"
                          FontFamily="Consolas" FontSize="12"
                          Command="{Binding AboutCommand}"/>
            </Menu>
        </Border>

        <!-- ░░ TOOLBAR ░░ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button Style="{StaticResource ToolbarButton}" Command="{Binding NewCommand}"       ToolTip="New"        Content="📄"/>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}"      ToolTip="Open"       Content="📂"/>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding SaveCommand}"      ToolTip="Save"       Content="💾"/>
                <Separator Width="1" Height="20" Margin="4,0"/>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExportPdfCommand}" ToolTip="Export PDF"
                        Content="📕" Foreground="{DynamicResource NeonPink}"/>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExportEpubCommand}" ToolTip="Export EPUB"
                        Content="📗" Foreground="{DynamicResource NeonCyan}"/>
                <Separator Width="1" Height="20" Margin="4,0"/>

                <!-- Text formatting -->
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.ToggleBold"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Bold (Ctrl+B)">
                    <TextBlock Text="B" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{DynamicResource PrimaryText}"/>
                </Button>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.ToggleItalic"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Italic (Ctrl+I)">
                    <TextBlock Text="I" FontStyle="Italic" FontFamily="Georgia"
                               Foreground="{DynamicResource PrimaryText}"/>
                </Button>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.ToggleUnderline"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Underline (Ctrl+U)">
                    <TextBlock Text="U" TextDecorations="Underline" FontFamily="Consolas"
                               Foreground="{DynamicResource PrimaryText}"/>
                </Button>
                <Separator Width="1" Height="20" Margin="4,0"/>

                <!-- Heading buttons -->
                <Button Style="{StaticResource FlatButton}" Padding="7,3"
                        Command="{Binding InsertHeadingCommand}" CommandParameter="h1"
                        ToolTip="Heading 1" Foreground="{DynamicResource NeonYellow}"
                        FontFamily="Consolas" FontSize="11">H1</Button>
                <Button Style="{StaticResource FlatButton}" Padding="7,3"
                        Command="{Binding InsertHeadingCommand}" CommandParameter="h2"
                        ToolTip="Heading 2" Foreground="{DynamicResource NeonYellow}"
                        FontFamily="Consolas" FontSize="11">H2</Button>
                <Button Style="{StaticResource FlatButton}" Padding="7,3"
                        Command="{Binding InsertHeadingCommand}" CommandParameter="h3"
                        ToolTip="Heading 3" Foreground="{DynamicResource NeonYellow}"
                        FontFamily="Consolas" FontSize="11">H3</Button>
                <Separator Width="1" Height="20" Margin="4,0"/>

                <!-- Alignment -->
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.AlignLeft"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Left"   Content="⫷"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.AlignCenter"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Center" Content="☰"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.AlignRight"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Right"  Content="⫸"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="EditingCommands.AlignJustify"
                        CommandTarget="{Binding ElementName=Editor}" ToolTip="Justify" Content="≣"/>
                <Separator Width="1" Height="20" Margin="4,0"/>
                <!-- Word count -->
                <TextBlock Text="{Binding WordCountText}"
                           Foreground="{DynamicResource SecondaryText}"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ░░ STATUS BAR ░░ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource NeonBorderDim}"
                BorderThickness="0,1,0,0" Height="26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{DynamicResource AccentText}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0" Effect="{StaticResource SubGlow}"/>
                <TextBlock Grid.Column="1" Text="{Binding DbStatsText}"
                           Foreground="{DynamicResource SecondaryText}" FontFamily="Consolas" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2"
                           x:Name="ClockText"
                           Text="// 00:00"
                           Foreground="{DynamicResource NeonCyan}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- ░░ MAIN 5-COLUMN LAYOUT ░░ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar chapters -->
                <ColumnDefinition Width="230" MinWidth="140"/>
                <!-- Splitter -->
                <ColumnDefinition Width="5"/>
                <!-- Editor -->
                <ColumnDefinition Width="*"/>
                <!-- Splitter -->
                <ColumnDefinition Width="5"/>

            </Grid.ColumnDefinitions>

            <!-- ── CHAPTER SIDEBAR ──────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Padding="10,8,10,6"
                            BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="// CHAPTERS" Foreground="{DynamicResource AccentText}"
                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                       Effect="{StaticResource SubGlow}"/>
                            <TextBox Text="{Binding BookTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0,0,0,1"
                                     BorderBrush="{DynamicResource NeonBorderDim}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource PrimaryText}"
                                     CaretBrush="{DynamicResource AccentBrush}"
                                     SelectionBrush="{DynamicResource SelectionBackground}"
                                     Padding="0,2"
                                     Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Action buttons -->
                    <Border DockPanel.Dock="Bottom" Padding="6,5"
                            BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0"
                            Background="{DynamicResource PanelBackground}">
                        <WrapPanel>
                            <Button Style="{StaticResource FlatButton}" Command="{Binding AddChapterCommand}"
                                    Content="+ NEW" Padding="8,4" Foreground="{DynamicResource NeonCyan}"/>
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding MoveChapterUpCommand}"   Content="↑"/>
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding MoveChapterDownCommand}" Content="↓"/>
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteChapterCommand}"
                                    Content="✕" Foreground="{DynamicResource NeonPink}"/>
                        </WrapPanel>
                    </Border>
                    <!-- List -->
                    <ListBox ItemContainerStyle="{StaticResource ChapterListItem}"
                             ItemsSource="{Binding Chapters}"
                             SelectedItem="{Binding SelectedChapter}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="4,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2,0,2">
                                    <!-- Chapter number + title -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Order, StringFormat='#{0} '}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding WordCountLabel}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontFamily="Consolas" FontSize="9"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu Background="{DynamicResource MenuBackground}"
                                         BorderBrush="{DynamicResource BorderBrush}">
                                <MenuItem Header="Rename…"       Command="{Binding DataContext.RenameChapterCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Save Revision" Command="{Binding DataContext.SaveRevisionCommand,    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="Delete"        Command="{Binding DataContext.DeleteChapterCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SeparatorBrush}" Opacity="0.5"/>

            <!-- ── EDITOR ──────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Chapter title editable bar -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,0,0,1"
                        Padding="16,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedChapter.Title, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource NeonCyan}"
                                 FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                 MaxWidth="580" HorizontalAlignment="Left"
                                 ToolTip="Rename chapter"/>
                        <Button Grid.Column="1" Style="{StaticResource FlatButton}"
                                Command="{Binding SaveRevisionCommand}"
                                Content="↺ SAVE REVISION"
                                Foreground="{DynamicResource SecondaryText}"
                                FontSize="11" Padding="8,3"/>
                    </Grid>
                </Border>

                <!-- Search/Replace panel (Ctrl+F) -->
                <Border x:Name="SearchPanel" Grid.Row="1"
                        Background="{DynamicResource ToolbarBackground}"
                        BorderBrush="{DynamicResource SeparatorBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,7" Visibility="Collapsed"
                        VerticalAlignment="Top" Panel.ZIndex="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌕" Foreground="{DynamicResource NeonCyan}"
                                   FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="SearchBox"
                                 Width="200" Margin="0,0,6,0"
                                 Tag="Найти…"
                                 KeyDown="SearchBox_KeyDown"/>
                        <TextBox x:Name="ReplaceBox"
                                 Width="200" Margin="0,0,8,0"
                                 Tag="Заменить на…"/>
                        <Button x:Name="FindPrevBtn" Content="▲" Style="{StaticResource ToolbarButton}"
                                Click="FindPrev_Click" ToolTip="Предыдущее (Shift+Enter)" Margin="0,0,2,0"/>
                        <Button x:Name="FindNextBtn" Content="▼" Style="{StaticResource ToolbarButton}"
                                Click="FindNext_Click" ToolTip="Следующее (Enter)" Margin="0,0,8,0"/>
                        <Button Content="Заменить" Style="{StaticResource ToolbarButton}"
                                Click="Replace_Click" Margin="0,0,4,0"/>
                        <Button Content="Заменить все" Style="{StaticResource ToolbarButton}"
                                Click="ReplaceAll_Click" Margin="0,0,12,0"/>
                        <TextBlock x:Name="SearchResultText"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="✕" Style="{StaticResource ToolbarButton}"
                                Click="CloseSearch_Click"
                                Foreground="{DynamicResource NeonPink}"/>
                    </StackPanel>
                </Border>

                <!-- Page / RichTextBox editor -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource EditorBackground}">
                    <Grid>
                        <!-- Scanline overlay -->
                        <Border IsHitTestVisible="False" Opacity="0.025">
                            <Border.Background>
                                <DrawingBrush TileMode="Tile" Viewport="0,0,1,3" ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="#00FFCC">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,4000,1"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Border.Background>
                        </Border>

                        <!-- Paper card -->
                        <Border Margin="36,20" MaxWidth="800"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource NeonBorderDim}"
                                BorderThickness="1" Padding="48,40">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FFCC" BlurRadius="22" ShadowDepth="0" Opacity="0.055"/>
                            </Border.Effect>
                            <RichTextBox x:Name="Editor"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PrimaryText}"
                                         BorderThickness="0"
                                         FontFamily="Consolas" FontSize="13"
                                         SpellCheck.IsEnabled="True"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         CaretBrush="{DynamicResource AccentBrush}"
                                         TextChanged="Editor_TextChanged">
                                <RichTextBox.Resources>
                                    <Style TargetType="Paragraph">
                                        <Setter Property="LineHeight"  Value="22"/>
                                        <Setter Property="Margin"      Value="0,4"/>
                                        <Setter Property="Foreground"  Value="{DynamicResource PrimaryText}"/>
                                        <Setter Property="FontFamily"  Value="Consolas"/>
                                        <Setter Property="FontSize"    Value="13"/>
                                    </Style>
                                    <Style TargetType="Run">
                                        <Setter Property="Foreground"  Value="{DynamicResource PrimaryText}"/>
                                        <Setter Property="FontFamily"  Value="Consolas"/>
                                        <Setter Property="FontSize"    Value="13"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
</Grid>
    </DockPanel>
</Window>
