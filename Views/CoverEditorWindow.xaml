<Window x:Class="BookWriter.Views.CoverEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="// COVER EDITOR" Width="560" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#050810" BorderBrush="#003322" BorderThickness="1">
    <Border Padding="24" Background="#070D1B" BorderBrush="#003322" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="// COVER EDITOR"
                       Foreground="#00FFCC" FontFamily="Consolas"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,16">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFCC" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Front cover -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="FRONT COVER" Foreground="#3A6080"
                               FontFamily="Consolas" FontSize="10" Margin="0,0,0,8"/>
                    <Border x:Name="FrontPreview" Height="220"
                            BorderBrush="#003322" BorderThickness="1"
                            Background="#030A0A">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="FrontLabel"
                                       Text="[ NO IMAGE ]"
                                       Foreground="#1A3A50"
                                       FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="LOAD FRONT…" Margin="0,8,0,0"
                            FontFamily="Consolas" FontSize="11"
                            Foreground="#00FFCC" Background="Transparent"
                            BorderBrush="#003322" BorderThickness="1"
                            Height="30" Cursor="Hand"
                            Click="LoadFront_Click"/>
                </StackPanel>

                <!-- Back cover -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="BACK COVER" Foreground="#3A6080"
                               FontFamily="Consolas" FontSize="10" Margin="0,0,0,8"/>
                    <Border x:Name="BackPreview" Height="220"
                            BorderBrush="#003322" BorderThickness="1"
                            Background="#030A0A">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="BackLabel"
                                       Text="[ NO IMAGE ]"
                                       Foreground="#1A3A50"
                                       FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="LOAD BACK…" Margin="0,8,0,0"
                            FontFamily="Consolas" FontSize="11"
                            Foreground="#00FFCC" Background="Transparent"
                            BorderBrush="#003322" BorderThickness="1"
                            Height="30" Cursor="Hand"
                            Click="LoadBack_Click"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="[ CANCEL ]" Width="100" Height="32" Margin="0,0,8,0"
                        FontFamily="Consolas" FontSize="11"
                        Foreground="#3A6080" Background="Transparent"
                        BorderBrush="#0D2235" Click="Cancel_Click"/>
                <Button Content="[ SAVE ]" Width="100" Height="32"
                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                        Foreground="#050810" Background="#00FFCC"
                        BorderBrush="#00FFCC" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
